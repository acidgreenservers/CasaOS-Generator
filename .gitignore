# CasaOS Generator - .gitignore for GitHub Pages deployment

# OS Files
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# IDE / Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Node / Dependencies (if ever used)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Environment
.env
.env.local
.env.production

# Logs
*.log

# Build output (future use)
dist/
build/

# Local config
generator_task_progress.json